{
  "name": "pitch-deck",
  "description": "Professional dark-to-light style. Use for persuasive storytelling — pitches, proposals, product launches. Follows a narrative arc: hook → problem → solution → proof → CTA. Tone: confident, data-driven.",
  "tags": ["business", "pitch", "storytelling", "professional"],
  "guide": {
    "palette": "Dark hero slides (#0B1D3A), white content slides, accent gradients (purple #6C5CE7, green #00B894, blue #0984E3). Cards use gradient fills with matching shadows.",
    "layout": "Hero slides: centered text stack. Content slides: section title at top + 2-column or 3-column card grid below. Metric slides: equal-width roundRect cards with large numbers.",
    "components": ["Centered hero heading (48–56pt)", "Section title (36pt bold, top-aligned)", "roundRect cards with gradient fill (icon-title-description pattern)", "Metric cards: big number + label", "Italic summary text below content"],
    "animations": "fadeIn for titles, flyIn (left/right/bottom) for cards with staggered delays (200ms). zoomIn for metric numbers. afterPrevious trigger throughout.",
    "customization": "Add or remove slides freely. Insert table slides for comparisons, image slides for product shots, or extra card rows. Adjust the narrative arc to fit your story — the pattern (hook → evidence → ask) works at any length."
  },
  "width": 13.333,
  "height": 7.5,
  "meta": { "title": "Pitch Deck", "author": "Startup Name" },
  "theme": {
    "colors": { "accent1": "6C5CE7", "accent2": "00B894", "dk1": "000000", "lt1": "FFFFFF" },
    "majorFont": "Calibri Light",
    "minorFont": "Calibri"
  },
  "slides": [
    {
      "background": "0B1D3A",
      "transition": { "type": "fade", "speed": "med" },
      "elements": [
        {
          "type": "text",
          "text": "Company Name",
          "position": { "x": 1, "y": 2, "w": 11.3, "h": 1.5 },
          "fontSize": 56,
          "bold": true,
          "color": "FFFFFF",
          "align": "center",
          "animations": [{ "type": "fadeIn", "duration": 800, "trigger": "afterPrevious" }]
        },
        {
          "type": "text",
          "text": "One-line description of what you do",
          "position": { "x": 2, "y": 3.8, "w": 9.3, "h": 0.8 },
          "fontSize": 24,
          "color": "7EB8DA",
          "align": "center",
          "animations": [{ "type": "fadeIn", "duration": 600, "trigger": "afterPrevious", "delay": 300 }]
        }
      ]
    },
    {
      "background": "FFFFFF",
      "transition": { "type": "push", "speed": "med" },
      "elements": [
        {
          "type": "text",
          "text": "The Problem",
          "position": { "x": 0.5, "y": 0.4, "w": 12.3, "h": 1 },
          "fontSize": 36,
          "bold": true,
          "color": "2D3436",
          "align": "center",
          "animations": [{ "type": "fadeIn", "duration": 500, "trigger": "afterPrevious" }]
        },
        {
          "type": "shape",
          "shapeType": "roundRect",
          "position": { "x": 0.5, "y": 1.8, "w": 5.9, "h": 2.5 },
          "fill": { "type": "gradient", "stops": [{ "position": 0, "color": "E17055" }, { "position": 100, "color": "D63031" }], "angle": 135 },
          "text": [
            { "text": "Pain Point 1", "fontSize": 20, "bold": true, "color": "FFFFFF" },
            { "text": "Describe the problem your users face", "fontSize": 14, "color": "FFDDDD" }
          ],
          "align": "center",
          "vertAlign": "middle",
          "shadow": { "blur": 8, "distance": 4, "angle": 45, "color": "000000", "opacity": 25 },
          "animations": [{ "type": "flyIn", "direction": "left", "duration": 600, "trigger": "afterPrevious", "delay": 200 }]
        },
        {
          "type": "shape",
          "shapeType": "roundRect",
          "position": { "x": 6.8, "y": 1.8, "w": 5.9, "h": 2.5 },
          "fill": { "type": "gradient", "stops": [{ "position": 0, "color": "E17055" }, { "position": 100, "color": "D63031" }], "angle": 135 },
          "text": [
            { "text": "Pain Point 2", "fontSize": 20, "bold": true, "color": "FFFFFF" },
            { "text": "Another problem worth solving", "fontSize": 14, "color": "FFDDDD" }
          ],
          "align": "center",
          "vertAlign": "middle",
          "shadow": { "blur": 8, "distance": 4, "angle": 45, "color": "000000", "opacity": 25 },
          "animations": [{ "type": "flyIn", "direction": "right", "duration": 600, "trigger": "afterPrevious", "delay": 200 }]
        },
        {
          "type": "text",
          "text": "Summarize the core problem in one sentence.",
          "position": { "x": 1, "y": 5, "w": 11.3, "h": 0.8 },
          "fontSize": 18,
          "italic": true,
          "color": "636E72",
          "align": "center",
          "animations": [{ "type": "fadeIn", "duration": 500, "trigger": "afterPrevious", "delay": 300 }]
        }
      ]
    },
