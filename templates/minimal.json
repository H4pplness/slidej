{
  "name": "minimal",
  "description": "Ultra-clean whitespace style. Use when content should speak for itself — academic talks, text-heavy presentations, simple briefings. No gradients, no decoration, just typography and space. Tone: calm, focused.",
  "tags": ["clean", "whitespace", "typography", "simple"],
  "guide": {
    "palette": "White background, near-black text (#1A1A1A), gray subtitles (#999999), medium gray body (#444444). Single dark accent line (#333333) as the only decoration.",
    "layout": "Left-aligned everything. Title slides: heading + thin horizontal rule + subtitle. Content slides: heading + thin rule + bullet list with generous line spacing. Closing: same as title.",
    "components": ["Left-aligned heading (48pt bold)", "Thin accent line (rect, 3\" wide, 0.06\" tall)", "Subtitle or date text (20pt gray)", "Bullet-point text blocks with 1.6x line spacing", "Simple closing text with contact info"],
    "animations": "fadeIn only, short durations (400–600ms). Minimal delay. Keep it quiet and understated.",
    "customization": "Add content slides by repeating the heading + rule + body pattern. For two-column layouts, place two text blocks side by side. Avoid shapes and gradients to maintain the minimal aesthetic — if you need emphasis, use bold or a slightly larger font size."
  },
  "width": 13.333,
  "height": 7.5,
  "meta": { "title": "Minimal Presentation", "author": "Author" },
  "theme": {
    "colors": { "accent1": "333333", "dk1": "000000", "lt1": "FFFFFF" },
    "majorFont": "Calibri Light",
    "minorFont": "Calibri"
  },
  "slides": [
    {
      "background": "FFFFFF",
      "transition": { "type": "fade", "speed": "med" },
      "elements": [
        {
          "type": "shape",
          "shapeType": "rect",
          "position": { "x": 0.5, "y": 3.5, "w": 3, "h": 0.06 },
          "fill": "333333"
        },
        {
          "type": "text",
          "text": "Presentation Title",
          "position": { "x": 0.5, "y": 1.5, "w": 10, "h": 1.8 },
          "fontSize": 48,
          "bold": true,
          "color": "1A1A1A",
          "align": "left",
          "animations": [{ "type": "fadeIn", "duration": 600, "trigger": "afterPrevious" }]
        },
        {
          "type": "text",
          "text": "Subtitle or date goes here",
          "position": { "x": 0.5, "y": 3.8, "w": 10, "h": 0.8 },
          "fontSize": 20,
          "color": "999999",
          "align": "left",
          "animations": [{ "type": "fadeIn", "duration": 400, "trigger": "afterPrevious", "delay": 200 }]
        }
      ]
    },
    {
      "background": "FFFFFF",
      "transition": { "type": "fade", "speed": "med" },
      "elements": [
        {
          "type": "text",
          "text": "Section Title",
          "position": { "x": 0.5, "y": 0.5, "w": 12, "h": 1 },
          "fontSize": 32,
          "bold": true,
          "color": "1A1A1A",
          "align": "left",
          "animations": [{ "type": "fadeIn", "duration": 500, "trigger": "afterPrevious" }]
        },
        {
          "type": "shape",
          "shapeType": "rect",
          "position": { "x": 0.5, "y": 1.4, "w": 2, "h": 0.05 },
          "fill": "333333"
        },
        {
          "type": "text",
          "text": [
            { "text": "First key point — explain your idea clearly and concisely.", "bullet": true },
            { "text": "Second key point — provide supporting evidence or data.", "bullet": true },
            { "text": "Third key point — describe the impact or next steps.", "bullet": true }
          ],
          "position": { "x": 0.5, "y": 2, "w": 11, "h": 4 },
          "fontSize": 20,
          "color": "444444",
          "lineSpacing": 1.6,
          "animations": [{ "type": "fadeIn", "duration": 500, "trigger": "afterPrevious", "delay": 200 }]
        }
      ]
    },
    {
      "background": "FFFFFF",
      "transition": { "type": "fade", "speed": "med" },
      "elements": [
        {
          "type": "shape",
          "shapeType": "rect",
          "position": { "x": 0.5, "y": 3.5, "w": 3, "h": 0.06 },
          "fill": "333333"
        },
        {
          "type": "text",
          "text": "Thank You",
          "position": { "x": 0.5, "y": 1.8, "w": 10, "h": 1.5 },
          "fontSize": 48,
          "bold": true,
          "color": "1A1A1A",
          "align": "left",
          "animations": [{ "type": "fadeIn", "duration": 600, "trigger": "afterPrevious" }]
        },
        {
          "type": "text",
          "text": "your.email@example.com",
          "position": { "x": 0.5, "y": 3.8, "w": 10, "h": 0.7 },
          "fontSize": 18,
          "color": "999999",
          "align": "left",
          "animations": [{ "type": "fadeIn", "duration": 400, "trigger": "afterPrevious", "delay": 200 }]
        }
      ]
    }
  ]
}
