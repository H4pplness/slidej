          "animations": [{ "type": "zoomIn", "duration": 500, "trigger": "afterPrevious", "delay": 200 }]
        },
        {
          "type": "shape",
          "shapeType": "roundRect",
          "position": { "x": 4.7, "y": 1.8, "w": 3.8, "h": 2.2 },
          "fill": "0984E3",
          "text": [
            { "text": "150%", "fontSize": 36, "bold": true, "color": "FFFFFF" },
            { "text": "MoM Growth", "fontSize": 14, "color": "CCE5FF" }
          ],
          "align": "center",
