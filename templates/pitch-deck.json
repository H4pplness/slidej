          ],
          "align": "center",
          "vertAlign": "middle",
          "shadow": { "blur": 6, "distance": 3, "angle": 45, "color": "000000", "opacity": 20 },
          "animations": [{ "type": "flyIn", "direction": "bottom", "duration": 500, "trigger": "afterPrevious", "delay": 200 }]
        },
        {
          "type": "shape",
          "shapeType": "roundRect",
          "position": { "x": 8.9, "y": 1.8, "w": 3.8, "h": 3 },
          "fill": { "type": "gradient", "stops": [{ "position": 0, "color": "6C5CE7" }, { "position": 100, "color": "5A4BD1" }], "angle": 135 },
          "text": [
            { "text": "Step 3", "fontSize": 20, "bold": true, "color": "FFFFFF" },
